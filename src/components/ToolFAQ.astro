---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faqs: FAQItem[];
}

const { faqs } = Astro.props;
---

<section class="mt-16 border-t border-gray-200 pt-12 dark:border-gray-800">
  <div class="mx-auto max-w-4xl">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8 text-center">Frequently Asked Questions</h2>
    <dl class="space-y-6">
      {faqs.map((faq, index) => (
        <div class="rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
          <dt class="text-base font-semibold text-gray-900 dark:text-white flex items-start gap-3">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-800 dark:bg-brand-950 dark:text-brand-400 font-bold text-xs">Q</span>
            <span>{faq.question}</span>
          </dt>
          <dd class="mt-3 text-sm text-gray-600 dark:text-gray-300 pl-9 border-l-2 border-brand-100 dark:border-brand-900">
            {faq.answer}
          </dd>
        </div>
      ))}
    </dl>
  </div>
</section>
