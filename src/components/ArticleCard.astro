---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
}

const { title, description, date, slug } = Astro.props;
---

<article class="flex flex-col items-start justify-between rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md dark:border-gray-800 dark:bg-gray-900">
  <div class="w-full">
    <div class="flex items-center gap-x-4 text-xs">
      <time datetime={date} class="text-gray-500 dark:text-gray-400">
        {date}
      </time>
      <span class="relative z-10 rounded-full bg-brand-50 px-3 py-1.5 font-medium text-brand-600 dark:bg-brand-950 dark:text-brand-400">
        Guide
      </span>
    </div>
    <div class="group relative">
      <h3 class="mt-3 text-lg font-semibold leading-6 text-gray-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400 transition-colors">
        <a href={`/blog/${slug}`}>
          <span class="absolute inset-0" />
          {title}
        </a>
      </h3>
      <p class="mt-2 line-clamp-3 text-sm leading-6 text-gray-600 dark:text-gray-400">
        {description}
      </p>
    </div>
  </div>
  <div class="mt-6 flex border-t border-gray-100 dark:border-gray-800 pt-4 w-full">
    <a href={`/blog/${slug}`} class="text-xs font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 flex items-center gap-1">
      Read full article
      <svg class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</article>
