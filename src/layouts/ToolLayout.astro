---
import Layout from './Layout.astro';
import RelatedTools from '../components/RelatedTools.astro';
import ToolFAQ from '../components/ToolFAQ.astro';
import ArticleCard from '../components/ArticleCard.astro';

interface FAQItem {
  question: string;
  answer: string;
}

interface ArticleItem {
  title: string;
  description: string;
  date: string;
  slug: string;
}

interface Props {
  title: string;
  description: string;
  h1: string;
  shortDescription: string;
  toolHref: string;
  faqs: FAQItem[];
  howToUseSteps: string[];
  relatedArticles?: ArticleItem[];
}

const {
  title,
  description,
  h1,
  shortDescription,
  toolHref,
  faqs,
  howToUseSteps,
  relatedArticles = [],
} = Astro.props;
---

<Layout title={title} description={description}>
  <div class="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumb -->
    <nav class="flex mb-4 text-xs font-medium text-gray-500 dark:text-gray-400" aria-label="Breadcrumb">
      <ol class="inline-flex items-center space-x-1 md:space-x-2">
        <li class="inline-flex items-center">
          <a href="/" class="hover:text-gray-900 dark:hover:text-white">Home</a>
        </li>
        <li>
          <div class="flex items-center">
            <svg class="w-3 h-3 mx-1 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 md:ml-2">Tools</span>
          </div>
        </li>
        <li aria-current="page">
          <div class="flex items-center">
            <svg class="w-3 h-3 mx-1 text-gray-400" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"></path>
            </svg>
            <span class="ml-1 md:ml-2 text-brand-600 dark:text-brand-400 font-semibold">{h1}</span>
          </div>
        </li>
      </ol>
    </nav>

    <!-- Header Content -->
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        {h1}
      </h1>
      <p class="mt-2 text-base text-gray-500 dark:text-gray-400 max-w-3xl">
        {shortDescription}
      </p>
    </div>

    <!-- Tool Work Area -->
    <div class="mb-12">
      <slot />
    </div>

    <!-- How to use -->
    {howToUseSteps && howToUseSteps.length > 0 && (
      <section class="mt-16 rounded-2xl border border-gray-200 bg-white p-8 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-6 flex items-center gap-2">
          <svg class="h-5 w-5 text-brand-600 dark:text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
          </svg>
          How to Use {h1}
        </h2>
        <ol class="grid grid-cols-1 gap-6 md:grid-cols-3">
          {howToUseSteps.map((step, index) => (
            <li class="relative flex flex-col sm:flex-row gap-4 items-start">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-brand-50 text-brand-700 dark:bg-brand-950/50 dark:text-brand-400 font-bold text-sm">
                0{index + 1}
              </span>
              <div class="mt-1">
                <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
                  {step}
                </p>
              </div>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- Related Articles -->
    {relatedArticles && relatedArticles.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Guides & Tutorials</h2>
        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {relatedArticles.map((article) => (
            <ArticleCard
              title={article.title}
              description={article.description}
              date={article.date}
              slug={article.slug}
            />
          ))}
        </div>
      </section>
    )}

    <!-- FAQs -->
    {faqs && faqs.length > 0 && <ToolFAQ faqs={faqs} />}

    <!-- Related Tools -->
    <RelatedTools excludeHref={toolHref} />
  </div>
</Layout>
