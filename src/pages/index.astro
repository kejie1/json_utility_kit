---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const tools = [
    {
        name: "JSON Formatter",
        description:
            "Beautify, validate, parse, and format JSON in your browser with adjustable indentation.",
        href: "/tools/json-formatter",
        icon: "M4 6h16M4 12h16M4 18h7",
    },
    {
        name: "JSON Validator",
        description:
            "Check and audit JSON syntax against specifications. Highlights line and character errors.",
        href: "/tools/json-validator",
        icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
    },
    {
        name: "JSON Beautifier",
        description:
            "Transform dense, unreadable JSON data arrays into pretty, readable formatted blocks.",
        href: "/tools/json-beautifier",
        icon: "M15 12a3 3 0 11-6 0 3 3 0 016 0z",
    },
    {
        name: "JSON Viewer",
        description:
            "Analyze nested JSON files by parsing them into an expandable, interactive nodes tree.",
        href: "/tools/json-viewer",
        icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253",
    },
    {
        name: "JSON Minifier",
        description:
            "Compress JSON objects by removing all line breaks, whitespaces, and tabs to save API bytes.",
        href: "/tools/json-minifier",
        icon: "M19 13l-7 7-7-7m14-6l-7 7-7-7",
    },
    {
        name: "JSON Editor",
        description:
            "Write and edit JSON properties interactively with instant feedback and keys-sorting options.",
        href: "/tools/json-editor",
        icon: "M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z",
    },
    {
        name: "JSON to CSV",
        description:
            "Flatten arrays of JSON objects into standard delimited spreadsheets for Google Sheets or Excel.",
        href: "/tools/json-to-csv",
        icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4",
    },
    {
        name: "CSV to JSON",
        description:
            "Convert CSV to JSON online. Export spreadsheet rows into clean JSON arrays with headers, quotes, and type parsing.",
        href: "/tools/csv-to-json",
        icon: "M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4",
    },
];

const faqs = [
    {
        q: "Does JSON Utility Kit store my data on a server?",
        a: "No. JSON Utility Kit processes all formatting, validation, editing, and conversion entirely client-side on your local machine using standard JavaScript. Your data never leaves your computer.",
    },
    {
        q: "Are these tools free to use?",
        a: "Yes! All features on JSON Utility Kit are 100% free, unlimited, and open-access. No subscriptions, logins, or paywalls are required.",
    },
    {
        q: "Can I format very large files?",
        a: "Yes, because the parsing runs directly in your browser without network overhead. However, pasting extremely large text documents (e.g. over 50MB) may hit standard browser engine memory performance thresholds.",
    },
];

// Load blog posts for home page guides
const allPosts = await getCollection("blog");
const recentPosts = allPosts
    .sort(
        (a, b) =>
            new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
    )
    .slice(0, 4);
---

<Layout
    title="JSON Utility Kit - Free Online JSON Tools"
    description="Format, validate, view, edit, minify, and convert JSON online. Fast browser-based JSON tools for developers and data users."
>
    <!-- Hero Section -->
    <section
        class="relative overflow-hidden bg-white dark:bg-gray-950 py-16 sm:py-24 border-b border-gray-100 dark:border-gray-900"
    >
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative">
            <div class="text-center max-w-3xl mx-auto">
                <!-- Secure Badge -->
                <div
                    class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3.5 py-1 text-xs font-semibold text-brand-700 dark:bg-brand-950/40 dark:text-brand-400 mb-6"
                >
                    <svg
                        class="h-3.5 w-3.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                        ></path>
                    </svg>
                    100% Private & Locally Processed
                </div>
                <h1
                    class="text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-6xl"
                >
                    JSON Utility Kit
                </h1>
                <p
                    class="mt-6 text-lg leading-relaxed text-gray-500 dark:text-gray-400"
                >
                    Format, validate, view, edit, minify, and convert JSON
                    directly in your browser. Fast, elegant, offline-ready
                    developer utilities with absolute data privacy.
                </p>
                <div class="mt-10 flex flex-wrap justify-center gap-4">
                    <a
                        href="/tools/json-formatter"
                        class="rounded-xl bg-brand-600 hover:bg-brand-700 text-white dark:bg-brand-500 dark:hover:bg-brand-600 px-6 py-3.5 text-sm font-bold shadow-sm transition flex items-center gap-1.5"
                    >
                        Open JSON Formatter
                        <svg
                            class="h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                    <a
                        href="#tools-section"
                        class="rounded-xl border border-gray-200 bg-white hover:bg-gray-50 dark:border-gray-800 dark:bg-gray-900 dark:hover:bg-gray-800 px-6 py-3.5 text-sm font-bold text-gray-700 dark:text-gray-300 transition"
                    >
                        Browse All Tools
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Tools Section -->
    <section
        id="tools-section"
        class="py-16 sm:py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8"
    >
        <div class="mx-auto max-w-2xl text-center mb-16">
            <h2
                class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl"
            >
                All Developer Utilities
            </h2>
            <p class="mt-4 text-base text-gray-500 dark:text-gray-400">
                Click on any utility below to open the standalone page. No
                backend processing, instantly parsed on your hardware.
            </p>
        </div>

        <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
            {
                tools.map((tool) => (
                    <a
                        href={tool.href}
                        class="group relative flex flex-col justify-between rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:shadow-md dark:border-gray-800 dark:bg-gray-900 hover:border-brand-500 dark:hover:border-brand-500"
                    >
                        <div>
                            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-600 dark:bg-brand-950 dark:text-brand-400 mb-5 group-hover:scale-110 transition-transform">
                                <svg
                                    class="h-6 w-6"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d={tool.icon}
                                    />
                                </svg>
                            </div>
                            <h3 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors">
                                {tool.name}
                            </h3>
                            <p class="mt-2 text-sm text-gray-500 dark:text-gray-400 leading-relaxed line-clamp-3">
                                {tool.description}
                            </p>
                        </div>
                        <div class="mt-6 flex items-center text-xs font-semibold text-brand-600 dark:text-brand-400">
                            Open Standalone Tool
                            <svg
                                class="h-3.5 w-3.5 ml-1 transition-transform group-hover:translate-x-1"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                viewBox="0 0 24 24"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9 5l7 7-7 7"
                                />
                            </svg>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>

    <!-- Security and Privacy Banner -->
    <section class="bg-gray-100 dark:bg-gray-900 py-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
            <div class="max-w-3xl mx-auto">
                <h2
                    class="text-2xl font-extrabold text-gray-900 dark:text-white sm:text-3xl"
                >
                    Complete Client-Side Confidentiality
                </h2>
                <p
                    class="mt-4 text-base text-gray-500 dark:text-gray-400 leading-relaxed"
                >
                    Pasting server secrets or database entries into internet
                    forums is highly unsafe. JSON Utility Kit resolves this
                    structural security issue by executing all computations
                    locally within your sandbox. No database storage, no remote
                    servers logs, absolutely zero risks of leak.
                </p>
                <div
                    class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3 text-left"
                >
                    <div
                        class="p-5 rounded-xl bg-white dark:bg-gray-950 border border-gray-200/50 dark:border-gray-800/50"
                    >
                        <h3
                            class="font-bold text-gray-900 dark:text-white text-sm"
                        >
                            Local Runtime
                        </h3>
                        <p
                            class="mt-1.5 text-xs text-gray-500 dark:text-gray-400"
                        >
                            Everything is processed via JavaScript directly in
                            your browser.
                        </p>
                    </div>
                    <div
                        class="p-5 rounded-xl bg-white dark:bg-gray-950 border border-gray-200/50 dark:border-gray-800/50"
                    >
                        <h3
                            class="font-bold text-gray-900 dark:text-white text-sm"
                        >
                            No Cloud DB
                        </h3>
                        <p
                            class="mt-1.5 text-xs text-gray-500 dark:text-gray-400"
                        >
                            We do not store, look, or upload your sensitive
                            documents anywhere.
                        </p>
                    </div>
                    <div
                        class="p-5 rounded-xl bg-white dark:bg-gray-950 border border-gray-200/50 dark:border-gray-800/50"
                    >
                        <h3
                            class="font-bold text-gray-900 dark:text-white text-sm"
                        >
                            Offline Functional
                        </h3>
                        <p
                            class="mt-1.5 text-xs text-gray-500 dark:text-gray-400"
                        >
                            Once loaded, you can disconnect from the internet
                            and continue using the tools.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Guides & Tutorials -->
    {
        recentPosts && recentPosts.length > 0 && (
            <section class="py-16 sm:py-24 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-end justify-between border-b border-gray-200 dark:border-gray-800 pb-5 mb-10">
                    <div>
                        <h2 class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white">
                            Developer Guides
                        </h2>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                            Read comprehensive step-by-step guides on editing
                            and formatting structured JSON arrays.
                        </p>
                    </div>
                    <a
                        href="/blog"
                        class="text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300"
                    >
                        View all guides &rarr;
                    </a>
                </div>

                <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
                    {recentPosts.map((post) => (
                        <article class="flex flex-col items-start justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:shadow-md dark:border-gray-800 dark:bg-gray-900 transition">
                            <div class="w-full">
                                <time
                                    datetime={post.data.date}
                                    class="text-[10px] font-semibold uppercase tracking-wider text-gray-400"
                                >
                                    {post.data.date}
                                </time>
                                <h3 class="mt-2 text-base font-bold text-gray-900 dark:text-white hover:text-brand-600 dark:hover:text-brand-400 transition-colors">
                                    <a href={`/blog/${post.slug}`}>
                                        {post.data.title}
                                    </a>
                                </h3>
                                <p class="mt-2 text-xs text-gray-500 dark:text-gray-400 line-clamp-3">
                                    {post.data.description}
                                </p>
                            </div>
                            <div class="mt-5 pt-3 border-t border-gray-100 dark:border-gray-800 w-full text-right">
                                <a
                                    href={`/blog/${post.slug}`}
                                    class="text-[11px] font-bold text-brand-600 dark:text-brand-400 hover:underline"
                                >
                                    Read Guide
                                </a>
                            </div>
                        </article>
                    ))}
                </div>
            </section>
        )
    }

    <!-- FAQ Section -->
    <section
        class="py-16 bg-white dark:bg-gray-950 border-t border-gray-100 dark:border-gray-900"
    >
        <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
            <h2
                class="text-2xl font-extrabold text-gray-900 dark:text-white sm:text-3xl text-center mb-12"
            >
                General FAQ
            </h2>
            <div class="space-y-6">
                {
                    faqs.map((faq) => (
                        <div class="rounded-xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
                            <h3 class="text-base font-bold text-gray-900 dark:text-white flex items-start gap-2.5">
                                <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-brand-100 text-brand-800 dark:bg-brand-950 dark:text-brand-400 font-bold text-[10px]">
                                    Q
                                </span>
                                <span>{faq.q}</span>
                            </h3>
                            <p class="mt-3 text-sm text-gray-600 dark:text-gray-400 pl-7 border-l border-gray-100 dark:border-gray-800">
                                {faq.a}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</Layout>
