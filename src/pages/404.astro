---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="404 Page Not Found - JSON Utility Kit"
    description="Sorry, the page you are looking for does not exist on JSON Utility Kit. Return home or check out our popular tools."
>
    <div class="mx-auto max-w-md px-4 py-24 sm:px-6 lg:px-8 text-center">
        <div class="flex justify-center mb-6">
            <div
                class="rounded-2xl bg-brand-50 p-4 dark:bg-brand-950/40 text-brand-600 dark:text-brand-400"
            >
                <svg
                    class="h-12 w-12"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                    ></path>
                </svg>
            </div>
        </div>
        <h1
            class="text-4xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-5xl"
        >
            404
        </h1>
        <h2 class="text-xl font-bold text-gray-800 dark:text-gray-200 mt-4">
            Page Not Found
        </h2>
        <p
            class="mt-3 text-sm text-gray-500 dark:text-gray-400 leading-relaxed"
        >
            Sorry, we couldn’t find the page you are looking for. It might have
            been moved or renamed.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3">
            <a
                href="/"
                class="rounded-xl bg-brand-600 hover:bg-brand-700 text-white dark:bg-brand-500 dark:hover:bg-brand-600 px-5 py-2.5 text-sm font-bold shadow-sm transition"
            >
                Go Back Home
            </a>
            <a
                href="/tools/json-formatter"
                class="rounded-xl border border-gray-200 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-gray-800 dark:text-gray-300 px-5 py-2.5 text-sm font-bold transition"
            >
                Open Formatter
            </a>
        </div>
    </div>
</Layout>
