---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
    const blogEntries = await getCollection("blog");
    return blogEntries.map((entry) => ({
        params: { slug: entry.slug },
        props: { entry },
    }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Layout
    title={`${entry.data.title} - JSON Utility Kit`}
    description={entry.data.description}
>
    <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Back to Blog -->
        <a
            href="/blog"
            class="inline-flex items-center gap-1 text-sm font-semibold text-brand-600 hover:text-brand-700 dark:text-brand-400 dark:hover:text-brand-300 mb-6"
        >
            <svg
                class="h-4 w-4"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
            </svg>
            Back to blog list
        </a>

        <!-- Header info -->
        <header class="border-b border-gray-200 pb-8 dark:border-gray-800">
            <div
                class="flex items-center gap-2 text-xs text-gray-500 dark:text-gray-400 mb-2"
            >
                <time datetime={entry.data.date}>{entry.data.date}</time>
                <span>&bull;</span>
                <span>Developer Guide</span>
            </div>
            <h1
                class="text-3xl font-extrabold tracking-tight text-gray-900 dark:text-white sm:text-4xl md:leading-tight"
            >
                {entry.data.h1}
            </h1>

            <!-- Short answer banner -->
            {
                entry.data.shortAnswer && (
                    <div class="mt-6 rounded-xl border border-brand-100 bg-brand-50/50 p-5 dark:border-brand-900/30 dark:bg-brand-950/20 text-gray-800 dark:text-gray-200">
                        <h2 class="text-xs font-bold uppercase tracking-wider text-brand-700 dark:text-brand-400 mb-1">
                            Quick Summary
                        </h2>
                        <p class="text-sm leading-relaxed font-medium">
                            {entry.data.shortAnswer}
                        </p>
                    </div>
                )
            }
        </header>

        <!-- Main Content Markdown styling -->
        <div
            class="prose prose-brand dark:prose-invert max-w-none mt-8 leading-relaxed text-gray-700 dark:text-gray-300 space-y-6"
        >
            <Content />
        </div>

        <!-- Related Tool Promotion Box -->
        {
            entry.data.relatedToolLink && (
                <div class="mt-16 rounded-2xl border border-gray-200 bg-white p-6 dark:border-gray-800 dark:bg-gray-900 shadow-sm flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
                    <div>
                        <h3 class="text-base font-bold text-gray-900 dark:text-white">
                            Need to work with JSON right now?
                        </h3>
                        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
                            Check out our 100% private, fast, browser-based
                            tools.
                        </p>
                    </div>
                    <a
                        href={entry.data.relatedToolLink}
                        class="inline-flex items-center justify-center rounded-xl bg-brand-600 hover:bg-brand-700 text-white dark:bg-brand-500 dark:hover:bg-brand-600 px-5 py-2.5 text-sm font-bold shadow-sm transition shrink-0 gap-1"
                    >
                        Open Free {entry.data.relatedToolName}
                        <svg
                            class="h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9 5l7 7-7 7"
                            />
                        </svg>
                    </a>
                </div>
            )
        }
    </div>
</Layout>

<style is:global>
    /* Markdown specific typographic styling */
    .prose h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--tw-prose-headings);
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        color: inherit;
    }
    .prose h3 {
        font-size: 1.2rem;
        font-weight: 600;
        margin-top: 1.5rem;
        margin-bottom: 0.5rem;
        color: inherit;
    }
    .prose hr {
        border-top: 1px solid rgba(156, 163, 175, 0.2);
        margin: 2rem 0;
    }
    .prose code:not(pre code) {
        background: rgba(156, 163, 175, 0.15);
        padding: 0.2rem 0.4rem;
        border-radius: 0.25rem;
        font-family: monospace;
        font-size: 0.875em;
    }
    .prose pre {
        background: #111827;
        color: #f3f4f6;
        padding: 1.25rem;
        border-radius: 0.75rem;
        overflow-x: auto;
        font-family: monospace;
        font-size: 0.875em;
        margin: 1.25rem 0;
    }
    .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5rem 0;
    }
    .prose th,
    .prose td {
        border: 1px solid rgba(156, 163, 175, 0.2);
        padding: 0.75rem;
        text-align: left;
    }
    .prose th {
        background: rgba(156, 163, 175, 0.05);
    }
    .prose ul,
    .prose ol {
        padding-left: 1.5rem;
        margin: 1rem 0;
    }
    .prose ul {
        list-style-type: disc;
    }
    .prose ol {
        list-style-type: decimal;
    }
</style>
