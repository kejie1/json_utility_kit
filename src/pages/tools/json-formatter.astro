---
import ToolLayout from '../../layouts/ToolLayout.astro';

const faqs = [
  {
    question: 'How does the JSON Formatter work?',
    answer: 'Our JSON Formatter parses your input JSON and re-serializes it with your chosen indentation (2 spaces, 4 spaces, or Tabs). The process happens entirely in your web browser, ensuring complete privacy.'
  },
  {
    question: 'Is my JSON data sent to any server?',
    answer: 'Absolutely not. All processing is executed client-side inside your browser. We do not transmit, save, or look at your data. It is 100% private.'
  },
  {
    question: 'What happens if there is an error in my JSON?',
    answer: 'If the input JSON is invalid, the formatter will show a detailed syntax error message, including the error reason and position, helping you fix the invalid characters.'
  }
];

const howToUseSteps = [
  'Paste your raw, minified, or messy JSON string into the input text editor.',
  'Select your preferred indentation option (2 spaces, 4 spaces, or Tabs).',
  'Click the "Format" button to beautify your JSON instantly, and click "Copy" or "Download" to save the formatted result.'
];

const relatedArticles = [
  {
    title: 'How to Format JSON: A Complete Guide',
    description: 'Learn various methods to format and beautify JSON, from browser-based tools to command-line utilities and IDE extensions.',
    date: '2026-06-10',
    slug: 'how-to-format-json'
  },
  {
    title: 'What Is JSON? An Introduction to JavaScript Object Notation',
    description: 'Discover the history, syntax, and use-cases of JSON, the web’s most popular data interchange format.',
    date: '2026-06-05',
    slug: 'what-is-json'
  }
];
---

<ToolLayout
  title="JSON Formatter Online - Format and Validate JSON"
  description="Format, beautify, and validate JSON online in your browser. Free JSON formatter with error messages, indentation options, copy, and download."
  h1="JSON Formatter Online"
  shortDescription="Format, beautify, and validate your JSON data in real-time. Safe, fast, and processed entirely inside your browser."
  toolHref="/tools/json-formatter"
  faqs={faqs}
  howToUseSteps={howToUseSteps}
  relatedArticles={relatedArticles}
>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Input Column -->
    <div class="flex flex-col h-full rounded-2xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
        <label for="json-input" class="text-sm font-semibold text-gray-700 dark:text-gray-300 flex items-center gap-1.5">
          <svg class="h-4 w-4 text-brand-600 dark:text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5" />
          </svg>
          Input JSON
        </label>
        <div class="flex items-center gap-2">
          <button id="btn-example" class="rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-800 dark:hover:bg-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-semibold transition">
            Load Example
          </button>
          <button id="btn-clear" class="rounded-lg bg-red-50 hover:bg-red-100 text-red-600 dark:bg-red-950/40 dark:hover:bg-red-950/70 dark:text-red-400 px-3 py-1.5 text-xs font-semibold transition">
            Clear
          </button>
        </div>
      </div>
      <textarea
        id="json-input"
        class="w-full h-96 min-h-[400px] rounded-xl border border-gray-200 bg-gray-50 p-4 font-mono text-sm leading-relaxed text-gray-800 focus:border-brand-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-brand-500 dark:border-gray-800 dark:bg-gray-950 dark:text-gray-200 dark:focus:border-brand-500 dark:focus:bg-gray-950 resize-y"
        placeholder='Paste your raw JSON string here...'
      ></textarea>
    </div>

    <!-- Output Column -->
    <div class="flex flex-col h-full rounded-2xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
        <label for="json-output" class="text-sm font-semibold text-gray-700 dark:text-gray-300 flex items-center gap-1.5">
          <svg class="h-4 w-4 text-brand-600 dark:text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Formatted Output
        </label>
        <div class="flex items-center gap-2">
          <button id="btn-copy" class="rounded-lg bg-brand-50 hover:bg-brand-100 text-brand-700 dark:bg-brand-950/50 dark:hover:bg-brand-950 dark:text-brand-400 px-3 py-1.5 text-xs font-semibold transition flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2" />
            </svg>
            Copy
          </button>
          <button id="btn-download" class="rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-800 dark:hover:bg-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-semibold transition flex items-center gap-1">
            <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Download
          </button>
        </div>
      </div>
      <div class="relative flex-grow flex flex-col">
        <textarea
          id="json-output"
          readonly
          class="w-full h-96 min-h-[400px] rounded-xl border border-gray-200 bg-gray-50 p-4 font-mono text-sm leading-relaxed text-gray-800 focus:outline-none dark:border-gray-800 dark:bg-gray-950 dark:text-gray-200 resize-y"
          placeholder="Formatted JSON will appear here..."
        ></textarea>
      </div>
    </div>
  </div>

  <!-- Options and Actions Bar -->
  <div class="mt-6 flex flex-wrap items-center justify-between gap-4 rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm">
    <!-- Options Left -->
    <div class="flex flex-wrap items-center gap-6">
      <div class="flex items-center gap-2">
        <span class="text-sm font-medium text-gray-500 dark:text-gray-400">Indentation:</span>
        <select id="indent-select" class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-gray-800 dark:bg-gray-950 dark:text-gray-300 focus:outline-none focus:ring-1 focus:ring-brand-500">
          <option value="2">2 Spaces</option>
          <option value="4" selected>4 Spaces</option>
          <option value="tab">Tab</option>
        </select>
      </div>
    </div>

    <!-- Actions Right -->
    <div class="flex items-center gap-3">
      <button id="btn-format" class="rounded-xl bg-brand-600 hover:bg-brand-700 text-white dark:bg-brand-500 dark:hover:bg-brand-600 px-6 py-2.5 text-sm font-bold shadow-sm transition flex items-center gap-1.5">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 7.89H18" />
        </svg>
        Format JSON
      </button>
    </div>
  </div>

  <!-- Feedback Panel -->
  <div id="feedback-panel" class="hidden mt-6 rounded-xl p-4 transition-all duration-200">
    <!-- Filled dynamically by JavaScript -->
  </div>
</ToolLayout>

<script>
  const jsonInput = document.getElementById('json-input') as HTMLTextAreaElement;
  const jsonOutput = document.getElementById('json-output') as HTMLTextAreaElement;
  const indentSelect = document.getElementById('indent-select') as HTMLSelectElement;
  
  const btnExample = document.getElementById('btn-example');
  const btnClear = document.getElementById('btn-clear');
  const btnCopy = document.getElementById('btn-copy');
  const btnDownload = document.getElementById('btn-download');
  const btnFormat = document.getElementById('btn-format');
  const feedbackPanel = document.getElementById('feedback-panel');

  const exampleJSON = {
    "name": "JSON Utility Kit",
    "version": "1.0.0",
    "description": "A fast, private, browser-based JSON toolkit.",
    "features": [
      "Formatter",
      "Validator",
      "Beautifier",
      "Viewer",
      "Minifier",
      "Editor"
    ],
    "privacy": {
      "isLocalOnly": true,
      "uploadData": false
    },
    "year": 2026
  };

  function updateFeedback(type: 'success' | 'error' | 'clear', message = '') {
    if (!feedbackPanel) return;
    if (type === 'clear') {
      feedbackPanel.classList.add('hidden');
      return;
    }

    feedbackPanel.classList.remove('hidden');
    if (type === 'success') {
      feedbackPanel.className = "mt-6 rounded-xl p-4 border border-brand-200 bg-brand-50 text-brand-800 dark:border-brand-900/30 dark:bg-brand-950/20 dark:text-brand-400";
      feedbackPanel.innerHTML = `
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 shrink-0 text-brand-600 dark:text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-semibold text-sm">${message || 'Valid JSON'}</span>
        </div>
      `;
    } else {
      feedbackPanel.className = "mt-6 rounded-xl p-4 border border-red-200 bg-red-50 text-red-800 dark:border-red-900/30 dark:bg-red-950/20 dark:text-red-400";
      feedbackPanel.innerHTML = `
        <div class="flex items-start gap-2">
          <svg class="h-5 w-5 shrink-0 text-red-600 dark:text-red-500 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div>
            <span class="font-semibold text-sm block">Invalid JSON Structure</span>
            <span class="text-xs font-mono block mt-1 opacity-90 break-all">${message}</span>
          </div>
        </div>
      `;
    }
  }

  function getIndentValue(): string | number {
    const val = indentSelect.value;
    if (val === 'tab') return '\t';
    return parseInt(val, 10);
  }

  function handleFormat() {
    const rawVal = jsonInput.value.trim();
    if (!rawVal) {
      updateFeedback('error', 'Please enter some JSON data.');
      return;
    }

    try {
      const parsed = JSON.parse(rawVal);
      const indent = getIndentValue();
      const formatted = JSON.stringify(parsed, null, indent);
      jsonOutput.value = formatted;
      updateFeedback('success', 'Valid JSON format and beautified successfully.');
    } catch (e: any) {
      updateFeedback('error', e.message);
    }
  }

  // Event Listeners
  btnExample?.addEventListener('click', () => {
    jsonInput.value = JSON.stringify(exampleJSON);
    updateFeedback('clear');
    handleFormat();
  });

  btnClear?.addEventListener('click', () => {
    jsonInput.value = '';
    jsonOutput.value = '';
    updateFeedback('clear');
  });

  btnFormat?.addEventListener('click', handleFormat);

  btnCopy?.addEventListener('click', () => {
    const outputText = jsonOutput.value;
    if (!outputText) return;
    navigator.clipboard.writeText(outputText).then(() => {
      const originalText = btnCopy.innerHTML;
      btnCopy.innerHTML = `
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Copied!
      `;
      setTimeout(() => {
        btnCopy.innerHTML = originalText;
      }, 1500);
    });
  });

  btnDownload?.addEventListener('click', () => {
    const outputText = jsonOutput.value;
    if (!outputText) return;
    const blob = new Blob([outputText], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'formatted.json';
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  });
</script>
