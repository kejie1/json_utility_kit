---
import ToolLayout from "../../layouts/ToolLayout.astro";

const faqs = [
    {
        question:
            "What is the difference between JSON formatting and beautifying?",
        answer: "Essentially they are the same thing. Both formatting and beautifying involve parsing unreadable minified JSON data and outputting it with clean indentation and spacing so that it’s human-readable.",
    },
    {
        question: "How many indentation styles do you support?",
        answer: "We support standard 2 spaces, 4 spaces, and Tab indentations. Choose whatever fits your code style guidelines.",
    },
];

const howToUseSteps = [
    "Paste your dense, single-line, or poorly styled JSON text into the input field.",
    "Choose your layout style (e.g., 2 spaces or 4 spaces).",
    'Click the "Beautify JSON" button to expand it with professional coding spacing.',
];

const relatedArticles = [
    {
        title: "JSON Minify vs. Beautify: When to Use Which?",
        description:
            "Understand the key differences between compressed JSON and formatted JSON, and when each format is ideal for production and development.",
        date: "2026-06-03",
        slug: "json-minify-vs-beautify",
    },
    {
        title: "How to Format JSON: A Complete Guide",
        description:
            "Learn various methods to format and beautify JSON, from browser-based tools to command-line utilities and IDE extensions.",
        date: "2026-06-10",
        slug: "how-to-format-json",
    },
];
---

<ToolLayout
    title="JSON Beautifier Online - Pretty Print JSON"
    description="Beautify and pretty print JSON online. Turn compact JSON into readable formatted JSON with indentation options."
    h1="JSON Beautifier Online"
    shortDescription="Pretty print messy and minified JSON instantly. Reformat keys and values into a readable developer-friendly structure."
    toolHref="/tools/json-beautifier"
    faqs={faqs}
    howToUseSteps={howToUseSteps}
    relatedArticles={relatedArticles}
>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Input Column -->
        <div
            class="flex flex-col h-full rounded-2xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm"
        >
            <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
                <label
                    for="json-input"
                    class="text-sm font-semibold text-gray-700 dark:text-gray-300 flex items-center gap-1.5"
                >
                    <svg
                        class="h-4 w-4 text-brand-600 dark:text-brand-500"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Messy JSON Input
                </label>
                <div class="flex items-center gap-2">
                    <button
                        id="btn-example"
                        class="rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-800 dark:hover:bg-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-semibold transition"
                    >
                        Load Example
                    </button>
                    <button
                        id="btn-clear"
                        class="rounded-lg bg-red-50 hover:bg-red-100 text-red-600 dark:bg-red-950/40 dark:hover:bg-red-950/70 dark:text-red-400 px-3 py-1.5 text-xs font-semibold transition"
                    >
                        Clear
                    </button>
                </div>
            </div>
            <textarea
                id="json-input"
                class="w-full h-96 min-h-[400px] rounded-xl border border-gray-200 bg-gray-50 p-4 font-mono text-sm leading-relaxed text-gray-800 focus:border-brand-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-brand-500 dark:border-gray-800 dark:bg-gray-950 dark:text-gray-200 dark:focus:border-brand-500 dark:focus:bg-gray-950 resize-y"
                placeholder='{"data":"paste your ugly json here..."}'
            ></textarea>
        </div>

        <!-- Output Column -->
        <div
            class="flex flex-col h-full rounded-2xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm"
        >
            <div class="flex flex-wrap items-center justify-between gap-4 mb-3">
                <label
                    for="json-output"
                    class="text-sm font-semibold text-gray-700 dark:text-gray-300 flex items-center gap-1.5"
                >
                    <svg
                        class="h-4 w-4 text-brand-600 dark:text-brand-500"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M5 13l4 4L19 7"></path>
                    </svg>
                    Beautified JSON
                </label>
                <div class="flex items-center gap-2">
                    <button
                        id="btn-copy"
                        class="rounded-lg bg-brand-50 hover:bg-brand-100 text-brand-700 dark:bg-brand-950/50 dark:hover:bg-brand-950 dark:text-brand-400 px-3 py-1.5 text-xs font-semibold transition flex items-center gap-1"
                    >
                        <svg
                            class="h-3.5 w-3.5"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2"
                            ></path>
                        </svg>
                        Copy
                    </button>
                    <button
                        id="btn-download"
                        class="rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 dark:bg-gray-800 dark:hover:bg-gray-700 dark:text-gray-300 px-3 py-1.5 text-xs font-semibold transition flex items-center gap-1"
                    >
                        <svg
                            class="h-3.5 w-3.5"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path>
                        </svg>
                        Download
                    </button>
                </div>
            </div>
            <div class="relative flex-grow flex flex-col">
                <textarea
                    id="json-output"
                    readonly
                    class="w-full h-96 min-h-[400px] rounded-xl border border-gray-200 bg-gray-50 p-4 font-mono text-sm leading-relaxed text-gray-800 focus:outline-none dark:border-gray-800 dark:bg-gray-950 dark:text-gray-200 resize-y"
                    placeholder="Readable pretty JSON will appear here..."
                ></textarea>
            </div>
        </div>
    </div>

    <!-- Actions Bar -->
    <div
        class="mt-6 flex flex-wrap items-center justify-between gap-4 rounded-xl border border-gray-200 bg-white p-4 dark:border-gray-800 dark:bg-gray-900 shadow-sm"
    >
        <div class="flex flex-wrap items-center gap-6">
            <div class="flex items-center gap-2">
                <span
                    class="text-sm font-medium text-gray-500 dark:text-gray-400"
                    >Pretty Size:</span
                >
                <select
                    id="indent-select"
                    class="rounded-lg border border-gray-200 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 dark:border-gray-800 dark:bg-gray-950 dark:text-gray-300 focus:outline-none focus:ring-1 focus:ring-brand-500"
                >
                    <option value="2" selected>2 Spaces (Clean)</option>
                    <option value="4">4 Spaces (Standard)</option>
                    <option value="tab">Tab Layout</option>
                </select>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button
                id="btn-beautify"
                class="rounded-xl bg-brand-600 hover:bg-brand-700 text-white dark:bg-brand-500 dark:hover:bg-brand-600 px-6 py-2.5 text-sm font-bold shadow-sm transition flex items-center gap-1.5"
            >
                <svg
                    class="h-4 w-4"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                Beautify JSON
            </button>
        </div>
    </div>

    <!-- Status Panel -->
    <div
        id="feedback-panel"
        class="hidden mt-6 rounded-xl p-4 transition-all duration-200"
    >
        <!-- Managed via script -->
    </div>
</ToolLayout>

<script>
    const jsonInput = document.getElementById(
        "json-input",
    ) as HTMLTextAreaElement;
    const jsonOutput = document.getElementById(
        "json-output",
    ) as HTMLTextAreaElement;
    const indentSelect = document.getElementById(
        "indent-select",
    ) as HTMLSelectElement;

    const btnExample = document.getElementById("btn-example");
    const btnClear = document.getElementById("btn-clear");
    const btnCopy = document.getElementById("btn-copy");
    const btnDownload = document.getElementById("btn-download");
    const btnBeautify = document.getElementById("btn-beautify");
    const feedbackPanel = document.getElementById("feedback-panel");

    const beautifyExample = {
        project: "JSON Utility Kit",
        speed: "instant",
        security: "100% private, no database logs",
        openSource: true,
        tech: ["Astro", "Tailwind", "TypeScript"],
    };

    function updateFeedback(type: "success" | "error" | "clear", message = "") {
        if (!feedbackPanel) return;
        if (type === "clear") {
            feedbackPanel.classList.add("hidden");
            return;
        }

        feedbackPanel.classList.remove("hidden");
        if (type === "success") {
            feedbackPanel.className =
                "mt-6 rounded-xl p-4 border border-brand-200 bg-brand-50 text-brand-800 dark:border-brand-900/30 dark:bg-brand-950/20 dark:text-brand-400";
            feedbackPanel.innerHTML = `
        <div class="flex items-center gap-2">
          <svg class="h-5 w-5 shrink-0 text-brand-600 dark:text-brand-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="font-semibold text-sm">${message || "Beautified successfully."}</span>
        </div>
      `;
        } else {
            feedbackPanel.className =
                "mt-6 rounded-xl p-4 border border-red-200 bg-red-50 text-red-800 dark:border-red-900/30 dark:bg-red-950/20 dark:text-red-400";
            feedbackPanel.innerHTML = `
        <div class="flex items-start gap-2">
          <svg class="h-5 w-5 shrink-0 text-red-600 dark:text-red-500 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
          <div>
            <span class="font-semibold text-sm block">Failed to Beautify</span>
            <span class="text-xs font-mono block mt-1 opacity-90 break-all">${message}</span>
          </div>
        </div>
      `;
        }
    }

    function handleBeautify() {
        const rawVal = jsonInput.value.trim();
        if (!rawVal) {
            updateFeedback("error", "Please enter some JSON to beautify.");
            return;
        }

        try {
            const parsed = JSON.parse(rawVal);
            const indentSel = indentSelect.value;
            const indent = indentSel === "tab" ? "\t" : parseInt(indentSel, 10);
            jsonOutput.value = JSON.stringify(parsed, null, indent);
            updateFeedback("success", "Perfect formatting applied.");
        } catch (e: any) {
            updateFeedback("error", e.message);
        }
    }

    btnExample?.addEventListener("click", () => {
        jsonInput.value = JSON.stringify(beautifyExample);
        updateFeedback("clear");
        handleBeautify();
    });

    btnClear?.addEventListener("click", () => {
        jsonInput.value = "";
        jsonOutput.value = "";
        updateFeedback("clear");
    });

    btnBeautify?.addEventListener("click", handleBeautify);

    btnCopy?.addEventListener("click", () => {
        const outputText = jsonOutput.value;
        if (!outputText) return;
        navigator.clipboard.writeText(outputText).then(() => {
            const originalText = btnCopy.innerHTML;
            btnCopy.innerHTML = `
        <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        Copied!
      `;
            setTimeout(() => {
                btnCopy.innerHTML = originalText;
            }, 1500);
        });
    });

    btnDownload?.addEventListener("click", () => {
        const outputText = jsonOutput.value;
        if (!outputText) return;
        const blob = new Blob([outputText], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "beautified.json";
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    });
</script>
